rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: cek user sudah login
    function isSignedIn() {
      return request.auth != null;
    }

    // Helper: cek user adalah pemilik data
    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    // ============ USERS ============
    match /users/{uid} {
      allow read: if isSignedIn();

      // Buat dokumen sendiri saat register
      allow create: if isOwner(uid);

      // Update: pemilik boleh update field profil miliknya sendiri
      // ATAU user lain boleh update HANYA field sosial (friend request dsb)
      allow update: if isOwner(uid)
        || (
          isSignedIn() &&
          request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['friends', 'sentRequests', 'receivedRequests'])
        );

      allow delete: if isOwner(uid);

      // ---- Subcollection: transactions ----
      match /transactions/{transactionId} {
        allow read: if isOwner(uid);

        // Client masih boleh create, tapi divalidasi ketat:
        allow create: if isOwner(uid)
          && request.resource.data.keys().hasAll(
               ['game_id', 'game_title', 'amount', 'currency', 'pdf_url', 'timestamp']
             )
          && request.resource.data.amount is number
          && request.resource.data.amount > 0
          && request.resource.data.game_id is string
          && request.resource.data.currency is string
          && request.resource.data.timestamp == request.time;

        // Transaksi tidak boleh diubah atau dihapus sekali dibuat (immutable)
        allow update, delete: if false;
      }
    }

    // ============ FAVORITE GAMES ============
    match /favorite_games/{gameId} {
      allow read: if isSignedIn();

      allow create: if isSignedIn()
        && request.resource.data.userId == request.auth.uid;

      allow update, delete: if isSignedIn()
        && resource.data.userId == request.auth.uid;
    }

    // ============ COMMENTS ============
    match /comments/{commentId} {
      // Publik: siapa saja bisa baca review, termasuk yang belum login
      allow read: if true;

      allow create: if isSignedIn()
        && request.resource.data.userId == request.auth.uid;

      allow update, delete: if isSignedIn()
        && resource.data.userId == request.auth.uid;
    }

    // ============ CHATS ============
    match /chats/{chatId} {
      allow read, update: if isSignedIn()
        && request.auth.uid in resource.data.participants;

      allow create: if isSignedIn()
        && request.auth.uid in request.resource.data.participants;

      allow delete: if false;

      // ---- Subcollection: messages ----
      match /messages/{messageId} {
        allow read: if isSignedIn()
          && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;

        allow create: if isSignedIn()
          && request.auth.uid == request.resource.data.senderId
          && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;

        allow update, delete: if false;
      }
    }

    // Default: tolak semua yang tidak match di atas
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
